{
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@4.0.0"
    }
  },
  "routes": [
    { "src": "/api/create-order", "dest": "/api/create-order.js" },
    { "src": "/api/capture-order", "dest": "/api/capture-order.js" },
    { "src": "/api/payout", "dest": "/api/payout.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
