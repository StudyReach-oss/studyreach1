{
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@4.0.0"
    }
  },
  "rewrites": [
    { "source": "/api/create-order", "destination": "/api/create-order.js" },
    { "source": "/api/capture-order", "destination": "/api/capture-order.js" },
    { "source": "/api/payout", "destination": "/api/payout.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
