{
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@4.0.0"
    }
  },
  "rewrites": [
    { "source": "/api/create-checkout-session", "destination": "/api/create-checkout-session.js" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/create-connect-account", "destination": "/api/create-connect-account.js" },
    { "source": "/api/payout", "destination": "/api/payout.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
