    if (savedToken && savedRole && ["researcher", "participant", "admin"].includes(savedRole)) {
      return savedRole; 
    }
    return "landing"; 
  });

  useEffect(() => {
    const savedToken = Storage.get("sb_token");
    const savedRole = Storage.get("sb_role");

    if (savedToken && savedRole) {
      if (view !== savedRole && ["researcher", "participant", "admin"].includes(savedRole)) {
        setView(savedRole);
      }
    }
  }, [view]);

  const nav = (target) => {
    setView(target);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const authDone = (role, token) => {
    if (token) Storage.set("sb_token", token);
    if (role) Storage.set("sb_role", role);
    setView(role);
